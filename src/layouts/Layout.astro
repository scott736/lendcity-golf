---
import '../styles/global.css';
import { event, absoluteUrl } from '../data/event';
import { getPageTitle, getPageDescription, getAllJsonLd } from '../lib/seo';
import { lendCityText } from '../lib/lendcity-mark';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = getPageTitle(),
  description = getPageDescription(),
  ogImage = absoluteUrl(event.ogImage),
  noindex = false,
} = Astro.props;

const canonicalUrl = absoluteUrl(Astro.url.pathname);
const jsonLd = getAllJsonLd();
const keywords = event.keywords.map((k) => lendCityText(k)).join(', ');
---

<!doctype html>
<html lang="en-CA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={lendCityText(event.organizer.name)} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM-readable site summary" />

    <!-- Local / geographic signals -->
    <meta name="geo.region" content="CA-ON" />
    <meta name="geo.placename" content={`${event.venue.city}, Ontario`} />
    <meta name="ICBM" content={`${event.venue.geo.latitude}, ${event.venue.geo.longitude}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={`${event.shortName} ${event.year}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={`${event.shortName} at ${event.venue.name}`} />
    <meta property="og:locale" content="en_CA" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#0A3C26" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link rel="icon" sizes="48x48" href="/favicon/favicon.ico" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="shortcut icon" href="/favicon/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500&family=Source+Sans+3:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />

    {
      jsonLd.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
