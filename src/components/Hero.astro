---
import { titleSponsor, sponsorRel } from '../data/sponsors';
import { event } from '../data/event';
import LendCityMark from './LendCityMark.astro';
---

<section class="relative flex min-h-screen items-center justify-center overflow-hidden pt-20">
  <!-- LCP hero image (discoverable in HTML, preloaded on the home page) -->
  <img
    src="/images/hero.webp"
    alt=""
    width="1920"
    height="1080"
    fetchpriority="high"
    decoding="async"
    class="absolute inset-0 h-full w-full object-cover"
    aria-hidden="true"
  />
  <div
    class="absolute inset-0 bg-gradient-to-b from-augusta-dark/80 via-augusta-dark/90 to-augusta-dark/98"
    aria-hidden="true"
  ></div>

  <!-- Subtle gold line grid overlay for that luxury feel -->
  <div class="absolute inset-0 opacity-10" aria-hidden="true">
    <div class="mx-auto h-full max-w-7xl border-x border-gold/30"></div>
  </div>

  <div class="relative mx-auto w-full max-w-7xl px-6 py-20 lg:py-28">
    <div class="grid items-center gap-12 lg:grid-cols-12 lg:gap-8">
      
      <!-- Left Column: Main Headline & Sponsor -->
      <div class="lg:col-span-7">
        <div class="animate-fade-up mb-4 inline-flex items-center gap-2 rounded-full border border-gold/30 bg-gold/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-gold-light">
          <span class="flex h-2 w-2 rounded-full bg-gold animate-pulse"></span>
          {event.year} Charity Golf Tournament
        </div>
        
        <h1
          class="animate-fade-up animate-fade-up-delay-1 font-display text-5xl font-bold leading-[1.1] text-white md:text-6xl lg:text-7xl"
        >
          <span class="block">
            <span class="text-gold-light">{event.year}</span>{' '}
            <LendCityMark variant="hero" />
          </span>
          <span class="mt-1 block whitespace-nowrap bg-gradient-to-r from-gold-light via-gold to-gold-light bg-clip-text text-transparent">
            Golf Classic
          </span>
        </h1>
        
        <p class="animate-fade-up animate-fade-up-delay-2 mt-6 max-w-xl text-lg leading-relaxed text-cream/80 md:text-xl">
          Join us for a premier day on the fairways. Connect with community leaders, enjoy world-class hospitality, and support a life-changing cause.
        </p>

        <!-- Buttons -->
        <div class="animate-fade-up animate-fade-up-delay-3 mt-8 flex flex-wrap gap-4">
          <a href="#register" class="btn-gold">
            Sign Up to Play
          </a>
          <a href="#about" class="btn-outline-white">
            Tournament Details
          </a>
        </div>

        <!-- Title Sponsor Badge -->
        <div class="animate-fade-up animate-fade-up-delay-3 mt-12 lg:mt-16">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-gold-light/60">Presented by Title Sponsor</p>
          <a
            href={titleSponsor.url}
            target="_blank"
            rel={sponsorRel(titleSponsor)}
            class="mt-3 inline-flex items-center rounded-xl border border-gold/20 bg-white/5 p-4 backdrop-blur-sm transition hover:border-gold/40 hover:bg-white/10"
          >
            <img
              src={titleSponsor.logo}
              alt={titleSponsor.name}
              width="480"
              height="113"
              class="h-10 w-auto max-w-[200px] object-contain brightness-0 invert md:h-12"
            />
          </a>
        </div>
      </div>

      <!-- Right Column: Luxury Invitation Card -->
      <div class="lg:col-span-5">
        <div class="animate-fade-up animate-fade-up-delay-2 clubhouse-card clubhouse-card-dark gold-border-frame relative overflow-hidden p-8 md:p-10">
          <div class="absolute -right-16 -top-16 h-32 w-32 rounded-full bg-gold/10 blur-2xl"></div>
          
          <div class="relative z-10 text-center">
            <span class="font-display text-lg italic text-gold-light">You are cordially invited</span>
            <div class="my-4 h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent"></div>
            
            <div class="space-y-6 text-left">
              <!-- Date -->
              <div class="flex items-start gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg border border-gold/30 bg-gold/10 text-gold-light">
                  <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-bold uppercase tracking-wider text-gold-light/60">Date & Time</p>
                  <p class="font-display text-lg font-bold text-white">Friday, July 17, 2026</p>
                  <p class="text-sm text-cream/60">{event.startTimeDisplay} Registration & Breakfast</p>
                </div>
              </div>

              <!-- Location -->
              <div class="flex items-start gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg border border-gold/30 bg-gold/10 text-gold-light">
                  <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-bold uppercase tracking-wider text-gold-light/60">Venue</p>
                  <p class="font-display text-lg font-bold text-white">Sutton Creek Golf Course</p>
                  <p class="text-sm text-cream/60">2135 County Rd 12, Essex, ON</p>
                </div>
              </div>

              <!-- Beneficiary -->
              <div class="flex items-start gap-4">
                <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg border border-gold/30 bg-gold/10 text-gold-light">
                  <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                  </svg>
                </div>
                <div>
                  <p class="text-xs font-bold uppercase tracking-wider text-gold-light/60">Proceeds Benefit</p>
                  <p class="font-display text-lg font-bold text-white">Harmony In Action</p>
                  <p class="text-sm text-cream/60">Supporting adults with disabilities</p>
                </div>
              </div>
            </div>

            <div class="mt-8">
              <a href="#register" class="block w-full rounded-full bg-white py-3 text-center text-sm font-bold uppercase tracking-wider text-augusta-dark transition hover:bg-gold-light hover:text-augusta-dark">
                Reserve Your Spot
              </a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<div class="stripe-fairway" aria-hidden="true"></div>
