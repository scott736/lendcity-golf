---
import SectionHeading from './SectionHeading.astro';
---

<section id="contact" class="dimple-pattern bg-cream py-20 lg:py-28">
  <div class="mx-auto max-w-4xl px-6">
    <SectionHeading
      label="Questions?"
      title="Contact the Committee"
      lead="Have questions about registration, sponsorship packages, or the event schedule? Send us a message and we will get back to you shortly."
      centered={true}
    />

    <div class="clubhouse-card gold-border-frame mt-12 p-8 md:p-10">
      <form id="contact-form" class="space-y-6">
        <div class="grid gap-6 md:grid-cols-2">
          <!-- Name -->
          <div>
            <label for="name" class="block text-xs font-bold uppercase tracking-wider text-navy">
              Full Name <span class="text-gold">*</span>
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              placeholder="John Doe"
              class="mt-2 w-full rounded-lg border border-sand bg-cream/50 px-4 py-3 text-sm text-ink outline-none transition duration-200 focus:border-gold focus:bg-white focus:ring-1 focus:ring-gold"
            />
          </div>

          <!-- Email -->
          <div>
            <label for="email" class="block text-xs font-bold uppercase tracking-wider text-navy">
              Email Address <span class="text-gold">*</span>
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              placeholder="john@example.com"
              class="mt-2 w-full rounded-lg border border-sand bg-cream/50 px-4 py-3 text-sm text-ink outline-none transition duration-200 focus:border-gold focus:bg-white focus:ring-1 focus:ring-gold"
            />
          </div>
        </div>

        <!-- Phone -->
        <div>
          <label for="phone" class="block text-xs font-bold uppercase tracking-wider text-navy">
            Phone Number <span class="text-muted/60">(Optional)</span>
          </label>
          <input
            type="tel"
            id="phone"
            name="phone"
            placeholder="(519) 555-0199"
            class="mt-2 w-full rounded-lg border border-sand bg-cream/50 px-4 py-3 text-sm text-ink outline-none transition duration-200 focus:border-gold focus:bg-white focus:ring-1 focus:ring-gold"
          />
        </div>

        <!-- Message -->
        <div>
          <label for="message" class="block text-xs font-bold uppercase tracking-wider text-navy">
            Message <span class="text-gold">*</span>
          </label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            placeholder="How can we help you?"
            class="mt-2 w-full rounded-lg border border-sand bg-cream/50 px-4 py-3 text-sm text-ink outline-none transition duration-200 focus:border-gold focus:bg-white focus:ring-1 focus:ring-gold"
          ></textarea>
        </div>

        <!-- Submit Button & Status -->
        <div class="flex flex-col items-center justify-between gap-4 pt-4 sm:flex-row">
          <p id="form-status" class="hidden text-sm font-semibold"></p>
          <button
            type="submit"
            id="submit-btn"
            class="btn-gold w-full sm:w-auto"
          >
            Send Message
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const statusEl = document.getElementById('form-status');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!form || !statusEl || !submitBtn) return;

    // Reset status
    statusEl.className = 'text-sm font-semibold text-muted';
    statusEl.textContent = 'Sending message...';
    statusEl.classList.remove('hidden');
    submitBtn.disabled = true;
    submitBtn.style.opacity = '0.7';

    const formData = new FormData(form);
    const payload = {
      name: formData.get('name'),
      email: formData.get('email'),
      phone: formData.get('phone'),
      message: formData.get('message'),
    };

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(payload),
      });

      const result = await response.json();

      if (response.ok && result.success) {
        statusEl.className = 'text-sm font-semibold text-augusta';
        statusEl.textContent = 'Thank you! Your message has been sent successfully.';
        form.reset();
      } else {
        statusEl.className = 'text-sm font-semibold text-red-600';
        statusEl.textContent = result.error || 'Failed to send message. Please try again.';
      }
    } catch (error) {
      console.error('Submission error:', error);
      statusEl.className = 'text-sm font-semibold text-red-600';
      statusEl.textContent = 'An unexpected error occurred. Please try again later.';
    } finally {
      submitBtn.disabled = false;
      submitBtn.style.opacity = '1';
    }
  });
</script>
