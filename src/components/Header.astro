---
const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#register', label: 'Register' },
  { href: '#sponsors', label: 'Sponsors' },
  { href: '#gallery', label: 'Gallery' },
  { href: '#faq', label: 'FAQ' },
  { href: '#contact', label: 'Contact' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 border-b border-sand bg-white/95 shadow-sm backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <a href="#" class="group flex items-center gap-3">
      <img
        src="/images/brand/lendcity-logo.png"
        alt="LendCity"
        class="h-9 w-auto transition-transform duration-300 group-hover:scale-102 md:h-10"
      />
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden items-center gap-8 md:flex">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="relative text-sm font-semibold uppercase tracking-wider text-muted transition-colors duration-200 hover:text-augusta"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center md:flex">
      <a href="#register" class="btn-augusta px-6 py-2.5 text-xs font-bold">
        Register Now
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-toggle"
      type="button"
      class="flex h-10 w-10 items-center justify-center rounded-lg border border-sand text-augusta hover:bg-cream-dark md:hidden"
      aria-label="Toggle Navigation Menu"
    >
      <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path
          id="menu-icon-hamburger"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"
        ></path>
        <path
          id="menu-icon-close"
          class="hidden"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"
        ></path>
      </svg>
    </button>
  </div>

  <!-- Mobile Dropdown Menu -->
  <div
    id="mobile-menu"
    class="hidden border-b border-sand bg-white px-6 py-6 shadow-lg md:hidden"
  >
    <nav class="flex flex-col gap-4">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="mobile-nav-link text-base font-semibold uppercase tracking-wider text-muted transition-colors hover:text-augusta"
          >
            {link.label}
          </a>
        ))
      }
      <a href="#register" class="btn-augusta mt-4 w-full text-center py-3 text-sm font-bold">
        Register Now
      </a>
    </nav>
  </div>
</header>

<script>
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('menu-icon-hamburger');
  const closeIcon = document.getElementById('menu-icon-close');
  const mobileLinks = document.querySelectorAll('.mobile-nav-link');

  function toggleMenu() {
    const isHidden = mobileMenu?.classList.contains('hidden');
    if (isHidden) {
      mobileMenu?.classList.remove('hidden');
      hamburgerIcon?.classList.add('hidden');
      closeIcon?.classList.remove('hidden');
    } else {
      mobileMenu?.classList.add('hidden');
      hamburgerIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    }
  }

  toggleBtn?.addEventListener('click', toggleMenu);

  mobileLinks.forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      hamburgerIcon?.classList.remove('hidden');
      closeIcon?.classList.add('hidden');
    });
  });
</script>
