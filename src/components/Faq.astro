---
import { faqs } from '../data/event';
import SectionHeading from './SectionHeading.astro';
---

<section id="faq" class="bg-white py-20 lg:py-28">
  <div class="mx-auto max-w-3xl px-6">
    <SectionHeading
      label="Questions & Answers"
      title="Tournament FAQ"
      lead="Everything golfers and sponsors need to know about the LendCity Charity Golf Tournament."
      centered={true}
    />

    <div class="mt-10 divide-y divide-sand border-y border-sand">
      {
        faqs.map((faq) => (
          <details class="group py-5">
            <summary class="flex cursor-pointer list-none items-start justify-between gap-4 font-display text-lg font-semibold text-navy marker:content-none">
              <span>{faq.question}</span>
              <span
                class="mt-1 shrink-0 text-gold transition-transform group-open:rotate-45"
                aria-hidden="true"
              >
                +
              </span>
            </summary>
            <p class="mt-3 pr-8 text-base leading-relaxed text-muted">{faq.answer}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
