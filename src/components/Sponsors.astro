---
import { sponsorTiers, sponsorRel, type SponsorTier } from '../data/sponsors';
import SectionHeading from './SectionHeading.astro';

function tierBadgeClass(tier: SponsorTier) {
  if (tier.id === 'title') {
    return 'border-gold/30 bg-gold/10 text-gold-dark';
  }
  if (tier.id === 'platinum' || tier.id === 'gold') {
    return 'border-navy/20 bg-navy/5 text-navy';
  }
  return 'border-sand bg-cream-dark text-muted';
}

function tierEmoji(tier: SponsorTier) {
  if (tier.id === 'title') return '🏆 ';
  return '';
}

function isPremierTier(tier: SponsorTier) {
  return tier.id === 'title' || tier.id === 'platinum' || tier.id === 'gold';
}

---

<section id="sponsors" class="bg-white py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-6">
    <SectionHeading
      label="Our Partners"
      title="Event Sponsors"
      lead="We are deeply grateful to our corporate sponsors whose generosity and support make this tournament possible. All proceeds go directly to Harmony In Action."
      centered={true}
    />

    {
      sponsorTiers.map((tier) => (
        <div class:list={['text-center', tier.layout === 'grid' ? 'mt-20' : 'mt-16']}>
          <span
            class:list={[
              'inline-block rounded-full border px-4 py-1.5 text-xs font-bold uppercase tracking-widest',
              tierBadgeClass(tier),
            ]}
          >
            {tierEmoji(tier)}
            {tier.label}
          </span>

          {
            isPremierTier(tier) ? (
              <div
                class:list={[
                  'mx-auto mt-6 grid gap-6',
                  tier.sponsors.length > 1 ? 'max-w-5xl sm:grid-cols-2' : 'max-w-2xl',
                ]}
              >
                {
                  tier.sponsors.map((sponsor) => {
                    const cardClass = tier.id === 'title'
                      ? 'clubhouse-card clubhouse-card-dark gold-border-frame block p-10 transition hover:-translate-y-0.5 md:p-14'
                      : 'clubhouse-card gold-border-frame block p-10 transition hover:-translate-y-0.5 md:p-14';
                    const imageClass = tier.id === 'title'
                      ? 'mx-auto h-24 w-full max-w-md object-contain brightness-0 invert md:h-32'
                      : 'mx-auto h-24 w-full max-w-md object-contain md:h-32';
                    const nameClass = tier.id === 'title'
                      ? 'font-display text-2xl font-bold text-gold-light'
                      : 'font-display text-2xl font-bold text-navy';
                    const subtitleClass = tier.id === 'title'
                      ? 'mt-1 text-sm text-cream/70'
                      : 'mt-1 text-sm text-muted';

                    return sponsor.url ? (
                      <a href={sponsor.url} target="_blank" rel={sponsorRel(sponsor)} class={cardClass}>
                        <img src={sponsor.logo} alt={sponsor.name} class={imageClass} />
                        <div class="mt-6 text-center">
                          <h3 class={nameClass}>{sponsor.name}</h3>
                          {
                            sponsor.subtitle ? (
                              <p class={subtitleClass}>{sponsor.subtitle}</p>
                            ) : tier.id === 'title' ? (
                              <p class="mt-1 text-sm uppercase tracking-wider text-cream/60">Official Presenting Partner</p>
                            ) : null
                          }
                        </div>
                      </a>
                    ) : (
                      <div class={cardClass.replace(' block', '')}>
                        <img src={sponsor.logo} alt={sponsor.name} class={imageClass} />
                        <div class="mt-6 text-center">
                          <h3 class={nameClass}>{sponsor.name}</h3>
                          {sponsor.subtitle ? <p class={subtitleClass}>{sponsor.subtitle}</p> : null}
                        </div>
                      </div>
                    );
                  })
                }
              </div>
            ) : tier.layout === 'featured' ? (
              <div
                class:list={[
                  'mx-auto mt-6 grid gap-6',
                  tier.sponsors.length > 1 ? 'max-w-5xl sm:grid-cols-2 lg:grid-cols-3' : 'max-w-xl',
                ]}
              >
                {
                  tier.sponsors.map((sponsor) =>
                    sponsor.url ? (
                      <a
                        href={sponsor.url}
                        target="_blank"
                        rel={sponsorRel(sponsor)}
                        class="clubhouse-card gold-border-frame block p-8 transition hover:-translate-y-0.5 md:p-10"
                      >
                        <img
                          src={sponsor.logo}
                          alt={sponsor.name}
                          class="mx-auto h-20 w-full max-w-sm object-contain md:h-24"
                        />
                        <div class="mt-5 text-center">
                          <h3 class="font-display text-xl font-bold text-navy">{sponsor.name}</h3>
                          {sponsor.subtitle ? <p class="mt-1 text-sm text-muted">{sponsor.subtitle}</p> : null}
                        </div>
                      </a>
                    ) : (
                      <div class="clubhouse-card gold-border-frame p-8 md:p-10">
                        <img
                          src={sponsor.logo}
                          alt={sponsor.name}
                          class="mx-auto h-20 w-full max-w-sm object-contain md:h-24"
                        />
                        <div class="mt-5 text-center">
                          <h3 class="font-display text-xl font-bold text-navy">{sponsor.name}</h3>
                          {sponsor.subtitle ? <p class="mt-1 text-sm text-muted">{sponsor.subtitle}</p> : null}
                        </div>
                      </div>
                    ),
                  )
                }
              </div>
            ) : (
              <div class="mt-8 grid grid-cols-2 gap-6 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
                {
                  tier.sponsors.map((sponsor) =>
                    sponsor.url ? (
                      <a
                        href={sponsor.url}
                        target="_blank"
                        rel={sponsorRel(sponsor)}
                        class="sponsor-card group flex h-44 flex-col items-center justify-center bg-cream/30 p-5 transition hover:-translate-y-0.5"
                      >
                        <div class="flex h-28 w-full items-center justify-center">
                          <img
                            src={sponsor.logo}
                            alt={sponsor.name}
                            title={sponsor.name}
                            class="max-h-full max-w-full object-contain"
                            loading="lazy"
                          />
                        </div>
                        <div class="mt-3 text-center">
                          <p class="text-xs font-bold uppercase tracking-wider text-muted/80">{sponsor.name}</p>
                          {sponsor.subtitle ? <p class="mt-1 text-[10px] leading-snug text-muted/70">{sponsor.subtitle}</p> : null}
                        </div>
                      </a>
                    ) : (
                      <div class="sponsor-card flex h-44 flex-col items-center justify-center bg-cream/30 p-5">
                        <div class="flex h-28 w-full items-center justify-center">
                          <img
                            src={sponsor.logo}
                            alt={sponsor.name}
                            title={sponsor.name}
                            class="max-h-full max-w-full object-contain"
                            loading="lazy"
                          />
                        </div>
                        <div class="mt-3 text-center">
                          <p class="text-xs font-bold uppercase tracking-wider text-muted/80">{sponsor.name}</p>
                          {sponsor.subtitle ? <p class="mt-1 text-[10px] leading-snug text-muted/70">{sponsor.subtitle}</p> : null}
                        </div>
                      </div>
                    ),
                  )
                }
              </div>
            )
          }
        </div>
      ))
    }

    <div class="clubhouse-card gold-border-frame mx-auto mt-20 max-w-3xl p-8 text-center md:p-10">
      <h3 class="font-display text-2xl font-bold text-navy">Partner With Us</h3>
      <p class="mx-auto mt-2 max-w-xl text-sm leading-relaxed text-muted">
        Sponsorship opportunities are limited. Align your brand with a trusted local charity and showcase
        your business to 100+ engaged community members.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-4">
        <a
          href="mailto:events@lendcity.ca?subject=LendCity%20Golf%20Sponsorship%202026"
          class="btn-gold"
        >
          Sponsorship Opportunities
        </a>
      </div>
    </div>
  </div>
</section>
