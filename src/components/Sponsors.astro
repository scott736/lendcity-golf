---
import { titleSponsor, sponsors, sponsorRel } from '../data/sponsors';
import SectionHeading from './SectionHeading.astro';
---

<section id="sponsors" class="bg-white py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-6">
    <SectionHeading
      label="Our Partners"
      title="Event Sponsors"
      lead="We are deeply grateful to our corporate sponsors whose generosity and support make this tournament possible. All proceeds go directly to Harmony In Action."
      centered={true}
    />

    <div class="mt-12 text-center">
      <span
        class="inline-block rounded-full border border-gold/30 bg-gold/10 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-gold-dark"
      >
        🏆 Title Sponsor
      </span>
      <div class="mx-auto mt-6 max-w-2xl">
        {
          titleSponsor.url ? (
            <a
              href={titleSponsor.url}
              target="_blank"
              rel={sponsorRel(titleSponsor)}
              class="clubhouse-card clubhouse-card-dark gold-border-frame block p-10 transition hover:-translate-y-0.5 md:p-14"
            >
              <img
                src={titleSponsor.logo}
                alt={titleSponsor.name}
                class="mx-auto h-24 w-full max-w-md object-contain brightness-0 invert md:h-32"
              />
              <div class="mt-6 text-center">
                <h3 class="font-display text-2xl font-bold text-gold-light">{titleSponsor.name}</h3>
                <p class="mt-1 text-sm uppercase tracking-wider text-cream/60">Official Presenting Partner</p>
              </div>
            </a>
          ) : (
            <div class="clubhouse-card clubhouse-card-dark gold-border-frame p-10 md:p-14">
              <img
                src={titleSponsor.logo}
                alt={titleSponsor.name}
                class="mx-auto h-24 w-full max-w-md object-contain brightness-0 invert md:h-32"
              />
              <div class="mt-6 text-center">
                <h3 class="font-display text-2xl font-bold text-gold-light">{titleSponsor.name}</h3>
                <p class="mt-1 text-sm uppercase tracking-wider text-cream/60">Official Presenting Partner</p>
              </div>
            </div>
          )
        }
      </div>
    </div>

    <div class="mt-24">
      <div class="mb-12 text-center">
        <span
          class="inline-block rounded-full border border-sand bg-cream-dark px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-muted"
        >
          Supporting Sponsors
        </span>
      </div>

      <div class="grid grid-cols-2 gap-6 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
        {
          sponsors.map((sponsor) =>
            sponsor.url ? (
              <a
                href={sponsor.url}
                target="_blank"
                rel={sponsorRel(sponsor)}
                class="sponsor-card group flex h-40 flex-col items-center justify-center bg-cream/30 p-5 transition hover:-translate-y-0.5"
              >
                <div class="flex h-28 w-full items-center justify-center">
                  <img
                    src={sponsor.logo}
                    alt={sponsor.name}
                    title={sponsor.name}
                    class="max-h-full max-w-full object-contain"
                    loading="lazy"
                  />
                </div>
                <p class="mt-3 text-center text-xs font-bold uppercase tracking-wider text-muted/80">
                  {sponsor.name}
                </p>
              </a>
            ) : (
              <div class="sponsor-card flex h-40 flex-col items-center justify-center bg-cream/30 p-5">
                <div class="flex h-28 w-full items-center justify-center">
                  <img
                    src={sponsor.logo}
                    alt={sponsor.name}
                    title={sponsor.name}
                    class="max-h-full max-w-full object-contain"
                    loading="lazy"
                  />
                </div>
                <p class="mt-3 text-center text-xs font-bold uppercase tracking-wider text-muted/80">
                  {sponsor.name}
                </p>
              </div>
            ),
          )
        }
      </div>
    </div>

    <div class="clubhouse-card gold-border-frame mx-auto mt-20 max-w-3xl p-8 text-center md:p-10">
      <h3 class="font-display text-2xl font-bold text-navy">Partner With Us</h3>
      <p class="mx-auto mt-2 max-w-xl text-sm leading-relaxed text-muted">
        Sponsorship opportunities are limited. Align your brand with a trusted local charity and showcase
        your business to 100+ engaged community members.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-4">
        <a
          href="mailto:events@lendcity.ca?subject=LendCity%20Golf%20Sponsorship%202026"
          class="btn-gold"
        >
          Sponsorship Opportunities
        </a>
      </div>
    </div>
  </div>
</section>
