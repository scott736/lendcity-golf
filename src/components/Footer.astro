---
import { event } from '../data/event';
import BrandedEventName from './BrandedEventName.astro';
import LendCityMark from './LendCityMark.astro';
---
<footer class="border-t border-gold/20 bg-augusta-dark py-16 text-white">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid gap-12 md:grid-cols-3">
      <div>
        <a href="https://lendcity.ca/" target="_blank" rel="noopener noreferrer" class="inline-block">
          <img
            src="/images/brand/lendcity-logo.png"
            alt="LendCity™ Mortgages"
            class="h-9 w-auto brightness-0 invert transition-opacity hover:opacity-80"
          />
        </a>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-cream/60">
          <BrandedEventName /> supporting Harmony In Action and adults with disabilities across Windsor-Essex.
        </p>
        <a
          href="https://lendcity.ca/"
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-block text-sm font-semibold text-gold-light transition-colors hover:text-white"
        >
          Visit lendcity.ca →
        </a>
      </div>

      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-gold-light">Event Details</h3>
        <ul class="mt-4 space-y-2 text-sm text-cream/60">
          <li>{event.dateDisplay}</li>
          <li>Sutton Creek Golf Course</li>
          <li>2135 County Rd 12, Essex, ON</li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-gold-light">Contact</h3>
        <ul class="mt-4 space-y-2 text-sm">
          <li>
            <a href="mailto:events@lendcity.ca" class="text-cream/60 transition-colors hover:text-white">
              events@lendcity.ca
            </a>
          </li>
          <li>
            <a href="tel:+15192521207" class="text-cream/60 transition-colors hover:text-white">(519) 252-1207</a>
          </li>
          <li>
            <a
              href="https://www.harmonyinaction.com"
              target="_blank"
              rel="nofollow noopener noreferrer"
              class="text-cream/60 transition-colors hover:text-white"
            >
              harmonyinaction.com
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-8 text-xs text-cream/40 md:flex-row"
    >
      <p>
        &copy; {new Date().getFullYear()}{' '}
        <a href="https://lendcity.ca/" target="_blank" rel="noopener noreferrer" class="text-cream/70 hover:text-white">
          <LendCityMark />
        </a>. All proceeds benefit Harmony In Action.
      </p>
      <p>
        Title Sponsor:{' '}
        <a
          href="https://navacord.com/"
          target="_blank"
          rel="nofollow noopener noreferrer"
          class="text-cream/70 hover:text-white"
        >
          Navacord
        </a>
      </p>
    </div>
  </div>
</footer>
